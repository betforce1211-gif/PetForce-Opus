{
  "name": "@petforce/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "clean": "rm -rf dist",
    "db:generate": "dotenv -e ../../.env.local -- drizzle-kit generate",
    "db:push": "dotenv -e ../../.env.local -- drizzle-kit push",
    "db:migrate": "tsx src/migrate.ts"
  },
  "dependencies": {
    "@petforce/core": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@petforce/config": "workspace:*",
    "@types/node": "^20.14.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.16.0",
    "typescript": "^5.4.0"
  }
}
