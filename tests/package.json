{
  "name": "@petforce/tests",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --config=playwright.config.ts",
    "test:e2e:screenshots": "playwright test --config=playwright.config.ts --reporter=list && echo '\nScreenshots saved to tests/test-results/screenshots/'",
    "test:coverage": "vitest run --coverage",
    "test:mobile": "cd mobile && maestro test flows/",
    "test:mobile:smoke": "cd mobile && maestro test --tags smoke flows/",
    "test:mobile:auth": "maestro test --tags auth tests/mobile/",
    "test:mobile:pets": "maestro test --tags pets tests/mobile/",
    "test:mobile:feeding": "maestro test --tags feeding tests/mobile/",
    "test:mobile:health": "maestro test --tags health tests/mobile/"
  },
  "devDependencies": {
    "@petforce/core": "workspace:*",
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.14.0",
    "playwright": "^1.45.0",
    "typescript": "^6.0.2",
    "vitest": "^2.0.0"
  }
}
