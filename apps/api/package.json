{
  "name": "@petforce/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./types": "./src/types.ts"
  },
  "scripts": {
    "dev": "dotenv -e ../../.env.local -- tsx watch src/index.ts",
    "dev:worker": "dotenv -e ../../.env.local -- tsx watch src/worker.ts",
    "build": "tsc",
    "start": "tsx dist/index.js",
    "start:worker": "node dist/worker.js",
    "lint": "eslint src/",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@clerk/backend": "^3.2.4",
    "@hono/node-server": "^1.19.12",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-prometheus": "^0.214.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-metrics": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@opentelemetry/sdk-trace-node": "^2.6.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@petforce/core": "workspace:*",
    "@petforce/db": "workspace:*",
    "@supabase/supabase-js": "^2.101.0",
    "@trpc/server": "^11.16.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "bullmq": "^5.34.0",
    "drizzle-orm": "^0.45.2",
    "file-type": "^22.0.0",
    "hono": "^4.12.9",
    "pino": "^10.3.1",
    "sharp": "^0.34.5",
    "superjson": "^2.2.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@petforce/config": "workspace:*",
    "@types/node": "^20.14.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.16.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
