# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/petforce

# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
CLERK_JWT_KEY=-----BEGIN PUBLIC KEY-----\nYOUR_CLERK_JWT_PUBLIC_KEY_HERE\n-----END PUBLIC KEY-----

# Clerk Auth (Mobile — Expo uses EXPO_PUBLIC_ prefix)
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# Supabase Storage (for pet avatar uploads — used by API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# API
API_PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WEB_URL=http://localhost:3000

# Supabase Management API (for PITR verification and DR scripts)
# SUPABASE_ACCESS_TOKEN=sbp_xxx
# SUPABASE_PROJECT_REF=your-project-ref

# Database Pool (optional — sensible defaults based on NODE_ENV)
# DATABASE_POOL_SIZE=20
# DB_STATEMENT_TIMEOUT=30000

# Rate Limiting + Caching (optional — falls back to in-memory if not set)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token

# Background Job Queue (optional — BullMQ requires a standard Redis connection)
# Use Upstash Redis endpoint or a self-hosted Redis instance
# REDIS_URL=redis://localhost:6379

# Notifications (optional — email and push degrade gracefully without them)
# RESEND_API_KEY=re_xxx
# RESEND_FROM_EMAIL=PetForce <notifications@petforce.app>
# EXPO_PUSH_ACCESS_TOKEN=your_expo_push_access_token
